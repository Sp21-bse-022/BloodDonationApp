@{
    ViewData["Title"] = "User Details";
    var user      = (BloodDonationApp.Models.ApplicationUser)ViewBag.User;
    var requests  = (IEnumerable<BloodDonationApp.Models.BloodRequest>)ViewBag.Requests;
    var donations = (IEnumerable<BloodDonationApp.Models.DonationHistory>)ViewBag.Donations;
    bool isAdmin  = (bool)ViewBag.IsAdmin;
}

<div class="container mt-4">

    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2><i class="bi bi-person-circle text-primary me-2"></i>User Details</h2>
        <a asp-action="Users" class="btn btn-outline-secondary">
            <i class="bi bi-arrow-left me-1"></i>Back to Users
        </a>
    </div>

    <!-- Profile Card -->
    <div class="row g-4 mb-4">
        <div class="col-md-5">
            <div class="card shadow-sm h-100">
                <div class="card-header @(isAdmin ? "bg-warning text-dark" : "bg-primary text-white")">
                    <h5 class="mb-0">
                        <i class="bi bi-@(isAdmin ? "shield-fill" : "person-fill") me-2"></i>
                        @(isAdmin ? "Admin" : "User") Profile
                    </h5>
                </div>
                <div class="card-body">
                    <dl class="row mb-0">
                        <dt class="col-5">Full Name</dt>
                        <dd class="col-7">@user.FullName</dd>

                        <dt class="col-5">Email</dt>
                        <dd class="col-7 text-break">@user.Email</dd>

                        <dt class="col-5">Blood Group</dt>
                        <dd class="col-7">
                            @if (!string.IsNullOrEmpty(user.BloodGroup))
                            { <span class="badge bg-danger">@user.BloodGroup</span> }
                            else { <span class="text-muted">Not set</span> }
                        </dd>

                        <dt class="col-5">City</dt>
                        <dd class="col-7">@(user.City ?? "—")</dd>

                        <dt class="col-5">Available</dt>
                        <dd class="col-7">
                            <span class="badge @(user.IsAvailable ? "bg-success" : "bg-secondary")">
                                @(user.IsAvailable ? "Yes" : "No")
                            </span>
                        </dd>

                        <dt class="col-5">Last Donation</dt>
                        <dd class="col-7">
                            @(user.LastDonationDate.HasValue
                                ? user.LastDonationDate.Value.ToString("MMM dd, yyyy")
                                : "Never")
                        </dd>

                        <dt class="col-5">Phone</dt>
                        <dd class="col-7">@(user.PhoneNumber ?? "—")</dd>
                    </dl>
                </div>
                @if (!isAdmin)
                {
                    <div class="card-footer d-flex gap-2">
                        <form asp-action="ToggleAvailability" asp-route-id="@user.Id" method="post">
                            @Html.AntiForgeryToken()
                            <button type="submit" class="btn btn-sm btn-outline-primary">
                                <i class="bi bi-toggle-on me-1"></i>Toggle Availability
                            </button>
                        </form>
                        <form asp-action="DeleteUser" asp-route-id="@user.Id" method="post"
                              onsubmit="return confirm('Delete this user and all their data permanently?')">
                            @Html.AntiForgeryToken()
                            <button type="submit" class="btn btn-sm btn-danger">
                                <i class="bi bi-trash me-1"></i>Delete User
                            </button>
                        </form>
                    </div>
                }
            </div>
        </div>

        <!-- Summary -->
        <div class="col-md-7">
            <div class="row g-3">
                <div class="col-6">
                    <div class="card border-0 shadow-sm text-center p-3">
                        <i class="bi bi-clipboard2-pulse text-warning" style="font-size:2rem;"></i>
                        <h3 class="mt-2 mb-0">@requests.Count()</h3>
                        <p class="text-muted mb-0">Blood Requests</p>
                    </div>
                </div>
                <div class="col-6">
                    <div class="card border-0 shadow-sm text-center p-3">
                        <i class="bi bi-heart-pulse text-success" style="font-size:2rem;"></i>
                        <h3 class="mt-2 mb-0">@donations.Count()</h3>
                        <p class="text-muted mb-0">Donations</p>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <!-- Blood Requests -->
    <div class="card shadow-sm mb-4">
        <div class="card-header bg-danger text-white">
            <h5 class="mb-0"><i class="bi bi-clipboard2-pulse me-2"></i>Blood Requests</h5>
        </div>
        <div class="card-body p-0">
            @if (!requests.Any())
            {
                <p class="text-muted p-3 mb-0">No blood requests.</p>
            }
            else
            {
                <div class="table-responsive">
                    <table class="table table-hover mb-0 align-middle">
                        <thead class="table-light">
                            <tr>
                                <th>Patient</th>
                                <th>Blood Group</th>
                                <th>Hospital</th>
                                <th>City</th>
                                <th>Urgency</th>
                                <th>Status</th>
                                <th>Date</th>
                                <th>Delete</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var r in requests)
                            {
                                <tr>
                                    <td>@r.PatientName</td>
                                    <td><span class="badge bg-danger">@r.BloodGroup</span></td>
                                    <td>@r.Hospital</td>
                                    <td>@r.City</td>
                                    <td>
                                        <span class="@(r.UrgencyLevel == BloodDonationApp.Models.UrgencyLevel.Critical ? "text-danger fw-bold" :
                                                       r.UrgencyLevel == BloodDonationApp.Models.UrgencyLevel.Urgent ? "text-warning fw-bold" : "text-success")">
                                            @r.UrgencyLevel
                                        </span>
                                    </td>
                                    <td>
                                        <span class="badge @(r.Status == BloodDonationApp.Models.RequestStatus.Open ? "bg-success" :
                                                             r.Status == BloodDonationApp.Models.RequestStatus.Fulfilled ? "bg-primary" : "bg-secondary")">
                                            @r.Status
                                        </span>
                                    </td>
                                    <td class="small">@r.CreatedAt.ToString("MMM dd, yyyy")</td>
                                    <td>
                                        <form asp-action="DeleteRequest" asp-route-id="@r.Id" method="post"
                                              onsubmit="return confirm('Delete this request?')">
                                            @Html.AntiForgeryToken()
                                            <button class="btn btn-outline-danger btn-sm">
                                                <i class="bi bi-trash"></i>
                                            </button>
                                        </form>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            }
        </div>
    </div>

    <!-- Donation History -->
    <div class="card shadow-sm">
        <div class="card-header bg-success text-white">
            <h5 class="mb-0"><i class="bi bi-heart-pulse me-2"></i>Donation History</h5>
        </div>
        <div class="card-body p-0">
            @if (!donations.Any())
            {
                <p class="text-muted p-3 mb-0">No donations recorded.</p>
            }
            else
            {
                <div class="table-responsive">
                    <table class="table table-hover mb-0 align-middle">
                        <thead class="table-light">
                            <tr>
                                <th>Date</th>
                                <th>Hospital</th>
                                <th>Notes</th>
                                <th>Delete</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var d in donations)
                            {
                                <tr>
                                    <td>@d.DonationDate.ToString("MMM dd, yyyy")</td>
                                    <td>@d.Hospital</td>
                                    <td>@(d.Notes ?? "—")</td>
                                    <td>
                                        <form asp-action="DeleteDonation" asp-route-id="@d.Id" method="post"
                                              onsubmit="return confirm('Delete this donation record?')">
                                            @Html.AntiForgeryToken()
                                            <button class="btn btn-outline-danger btn-sm">
                                                <i class="bi bi-trash"></i>
                                            </button>
                                        </form>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            }
        </div>
    </div>
</div>
