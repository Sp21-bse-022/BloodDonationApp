@model BloodRequest
@{
    ViewData["Title"] = "Request Details";
}

<div class="container mt-4">
    <div class="row justify-content-center">
        <div class="col-md-7">
            <div class="card shadow-sm">
                <div class="card-header bg-danger text-white py-3 d-flex justify-content-between align-items-center">
                    <h4 class="mb-0"><i class="bi bi-info-circle me-2"></i>Blood Request Details</h4>
                    <span class="badge bg-light text-danger fs-6">@Model.BloodGroup</span>
                </div>
                <div class="card-body p-4">
                    <dl class="row">
                        <dt class="col-sm-4">Patient Name</dt>
                        <dd class="col-sm-8">@Model.PatientName</dd>

                        <dt class="col-sm-4">Hospital</dt>
                        <dd class="col-sm-8">@Model.Hospital</dd>

                        <dt class="col-sm-4">City</dt>
                        <dd class="col-sm-8">@Model.City</dd>

                        <dt class="col-sm-4">Units Needed</dt>
                        <dd class="col-sm-8">@Model.UnitsNeeded</dd>

                        <dt class="col-sm-4">Urgency</dt>
                        <dd class="col-sm-8">
                            <span class="@(Model.UrgencyLevel == UrgencyLevel.Critical ? "urgency-critical" :
                                           Model.UrgencyLevel == UrgencyLevel.Urgent ? "urgency-urgent" : "urgency-normal")">
                                @Model.UrgencyLevel
                            </span>
                        </dd>

                        <dt class="col-sm-4">Contact</dt>
                        <dd class="col-sm-8">
                            <a href="tel:@Model.ContactNumber">@Model.ContactNumber</a>
                        </dd>

                        <dt class="col-sm-4">Status</dt>
                        <dd class="col-sm-8">
                            <span class="badge @(Model.Status == RequestStatus.Open ? "bg-success" :
                                                 Model.Status == RequestStatus.Fulfilled ? "bg-primary" : "bg-secondary")">
                                @Model.Status
                            </span>
                        </dd>

                        <dt class="col-sm-4">Posted By</dt>
                        <dd class="col-sm-8">@(Model.User?.FullName ?? "—")</dd>

                        <dt class="col-sm-4">Posted On</dt>
                        <dd class="col-sm-8">@Model.CreatedAt.ToString("MMMM dd, yyyy HH:mm") UTC</dd>
                    </dl>
                </div>
                <div class="card-footer d-flex gap-2">
                    <a asp-action="Index" class="btn btn-outline-secondary">
                        <i class="bi bi-arrow-left me-1"></i>Back to List
                    </a>
                    @if (User.Identity?.IsAuthenticated == true &&
                         User.FindFirst(System.Security.Claims.ClaimTypes.NameIdentifier)?.Value == Model.UserId)
                    {
                        <a asp-action="Edit" asp-route-id="@Model.Id" class="btn btn-warning">
                            <i class="bi bi-pencil me-1"></i>Edit
                        </a>
                    }
                </div>
            </div>
        </div>
    </div>
</div>
