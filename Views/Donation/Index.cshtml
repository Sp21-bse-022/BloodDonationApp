@model IEnumerable<DonationHistory>
@{
    ViewData["Title"] = "My Donations";
}

<div class="container mt-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2><i class="bi bi-heart-pulse-fill text-danger me-2"></i>My Donation History</h2>
        <a asp-action="Create" class="btn btn-danger">
            <i class="bi bi-plus-circle me-1"></i>Record Donation
        </a>
    </div>

    @if (TempData["Success"] != null)
    {
        <div class="alert alert-success alert-dismissible fade show" role="alert">
            <i class="bi bi-check-circle me-2"></i>@TempData["Success"]
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    }

    @if (!Model.Any())
    {
        <div class="text-center py-5">
            <i class="bi bi-heart text-muted" style="font-size: 4rem;"></i>
            <h4 class="mt-3 text-muted">No donations recorded yet</h4>
            <a asp-action="Create" class="btn btn-danger mt-3">Record Your First Donation</a>
        </div>
    }
    else
    {
        <div class="table-responsive">
            <table class="table table-hover align-middle">
                <thead class="table-danger">
                    <tr>
                        <th>#</th>
                        <th>Date</th>
                        <th>Hospital</th>
                        <th>Notes</th>
                        <th>Actions</th>
                    </tr>
                </thead>
                <tbody>
                    @{int i = 1;}
                    @foreach (var d in Model)
                    {
                        <tr>
                            <td>@i++</td>
                            <td>@d.DonationDate.ToString("MMM dd, yyyy")</td>
                            <td>@d.Hospital</td>
                            <td>@(d.Notes ?? "—")</td>
                            <td>
                                <form asp-action="Delete" asp-route-id="@d.Id" method="post"
                                      onsubmit="return confirm('Delete this record?')">
                                    @Html.AntiForgeryToken()
                                    <button type="submit" class="btn btn-outline-danger btn-sm">
                                        <i class="bi bi-trash"></i>
                                    </button>
                                </form>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    }
</div>
