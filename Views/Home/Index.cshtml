@model IEnumerable<BloodRequest>
@{
    ViewData["Title"] = "Home";
}

<!-- Hero Section -->
<section class="hero-section text-center">
    <div class="container">
        <h1 class="display-4 fw-bold mb-3">
            <i class="bi bi-droplet-fill me-2"></i>Save Lives Through Blood Donation
        </h1>
        <p class="lead mb-4">
            Connect donors with those in need. Every donation counts.
        </p>
        @if (User.Identity?.IsAuthenticated == true)
        {
            <a asp-controller="BloodRequest" asp-action="Create" class="btn btn-light btn-lg px-5">
                <i class="bi bi-plus-circle me-2"></i>Create Blood Request
            </a>
        }
        else
        {
            <a asp-controller="Account" asp-action="Register" class="btn btn-light btn-lg px-5 me-2">
                <i class="bi bi-person-plus me-2"></i>Register as Donor
            </a>
            <a asp-controller="Account" asp-action="Login" class="btn btn-outline-light btn-lg px-5">
                <i class="bi bi-box-arrow-in-right me-2"></i>Login
            </a>
        }
    </div>
</section>

<!-- Stats Section -->
<section class="py-5">
    <div class="container">
        <div class="row g-4">
            <div class="col-md-4">
                <div class="card stat-card text-center p-4">
                    <div class="card-body">
                        <i class="bi bi-people-fill text-danger" style="font-size: 3rem;"></i>
                        <h2 class="mt-3 mb-0">@ViewBag.TotalDonors</h2>
                        <p class="text-muted mb-0">Available Donors</p>
                    </div>
                </div>
            </div>
            <div class="col-md-4">
                <div class="card stat-card text-center p-4">
                    <div class="card-body">
                        <i class="bi bi-heart-pulse-fill text-danger" style="font-size: 3rem;"></i>
                        <h2 class="mt-3 mb-0">@ViewBag.OpenRequests</h2>
                        <p class="text-muted mb-0">Open Requests</p>
                    </div>
                </div>
            </div>
            <div class="col-md-4">
                <div class="card stat-card text-center p-4">
                    <div class="card-body">
                        <i class="bi bi-droplet-fill text-danger" style="font-size: 3rem;"></i>
                        <h2 class="mt-3 mb-0">@ViewBag.TotalDonations</h2>
                        <p class="text-muted mb-0">Total Donations</p>
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>

<!-- Recent Requests Section -->
@if (Model != null && Model.Any())
{
    <section class="py-5 bg-white">
        <div class="container">
            <h2 class="text-center mb-4">
                <i class="bi bi-exclamation-circle-fill text-danger me-2"></i>Recent Blood Requests
            </h2>
            <div class="row g-4">
                @foreach (var request in Model)
                {
                    <div class="col-md-6 col-lg-4">
                        <div class="card stat-card h-100">
                            <div class="card-body">
                                <div class="d-flex justify-content-between align-items-start mb-3">
                                    <h5 class="card-title mb-0">@request.PatientName</h5>
                                    <span class="badge bg-danger fs-6">@request.BloodGroup</span>
                                </div>
                                <p class="mb-2">
                                    <i class="bi bi-hospital me-2 text-muted"></i>@request.Hospital
                                </p>
                                <p class="mb-2">
                                    <i class="bi bi-geo-alt me-2 text-muted"></i>@request.City
                                </p>
                                <p class="mb-2">
                                    <i class="bi bi-droplet me-2 text-muted"></i>@request.UnitsNeeded units needed
                                </p>
                                <p class="mb-3">
                                    <i class="bi bi-exclamation-triangle me-2"></i>
                                    <span class="@(request.UrgencyLevel == UrgencyLevel.Critical ? "urgency-critical" :
                                                   request.UrgencyLevel == UrgencyLevel.Urgent ? "urgency-urgent" : "urgency-normal")">
                                        @request.UrgencyLevel
                                    </span>
                                </p>
                                <a asp-controller="BloodRequest" asp-action="Details" asp-route-id="@request.Id"
                                   class="btn btn-outline-danger w-100">
                                    <i class="bi bi-info-circle me-1"></i>View Details
                                </a>
                            </div>
                        </div>
                    </div>
                }
            </div>
            <div class="text-center mt-4">
                <a asp-controller="BloodRequest" asp-action="Index" class="btn btn-danger btn-lg">
                    View All Requests <i class="bi bi-arrow-right ms-2"></i>
                </a>
            </div>
        </div>
    </section>
}
else
{
    <section class="py-5 bg-white">
        <div class="container text-center">
            <i class="bi bi-inbox text-muted" style="font-size: 4rem;"></i>
            <h3 class="mt-3 text-muted">No active blood requests at the moment</h3>
        </div>
    </section>
}
