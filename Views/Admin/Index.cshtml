@model IEnumerable<BloodDonationApp.Models.BloodRequest>
@{
    ViewData["Title"] = "Admin Dashboard";
}

<div class="container-fluid mt-4">

    <div class="d-flex align-items-center mb-4">
        <i class="bi bi-shield-lock-fill text-danger me-2" style="font-size:2rem;"></i>
        <h2 class="mb-0">Admin Dashboard</h2>
    </div>

    @if (TempData["Success"] != null)
    {
        <div class="alert alert-success alert-dismissible fade show">
            <i class="bi bi-check-circle me-2"></i>@TempData["Success"]
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    }
    @if (TempData["Error"] != null)
    {
        <div class="alert alert-danger alert-dismissible fade show">
            <i class="bi bi-exclamation-triangle me-2"></i>@TempData["Error"]
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    }

    <!-- Stat Cards -->
    <div class="row g-4 mb-5">
        <div class="col-sm-6 col-xl-3">
            <div class="card border-0 shadow-sm text-center p-3">
                <i class="bi bi-people-fill text-primary" style="font-size:2.5rem;"></i>
                <h3 class="mt-2 mb-0">@ViewBag.TotalUsers</h3>
                <p class="text-muted mb-0">Total Users</p>
                <a asp-action="Users" class="stretched-link"></a>
            </div>
        </div>
        <div class="col-sm-6 col-xl-3">
            <div class="card border-0 shadow-sm text-center p-3">
                <i class="bi bi-droplet-fill text-danger" style="font-size:2.5rem;"></i>
                <h3 class="mt-2 mb-0">@ViewBag.TotalDonors</h3>
                <p class="text-muted mb-0">Available Donors</p>
                <a asp-action="Users" class="stretched-link"></a>
            </div>
        </div>
        <div class="col-sm-6 col-xl-3">
            <div class="card border-0 shadow-sm text-center p-3">
                <i class="bi bi-clipboard2-pulse-fill text-warning" style="font-size:2.5rem;"></i>
                <h3 class="mt-2 mb-0">@ViewBag.OpenRequests</h3>
                <p class="text-muted mb-0">Open Requests</p>
                <a asp-action="Requests" class="stretched-link"></a>
            </div>
        </div>
        <div class="col-sm-6 col-xl-3">
            <div class="card border-0 shadow-sm text-center p-3">
                <i class="bi bi-heart-pulse-fill text-success" style="font-size:2.5rem;"></i>
                <h3 class="mt-2 mb-0">@ViewBag.TotalDonations</h3>
                <p class="text-muted mb-0">Total Donations</p>
                <a asp-action="Donations" class="stretched-link"></a>
            </div>
        </div>
    </div>

    <!-- Quick Nav -->
    <div class="row g-3 mb-5">
        <div class="col-md-4">
            <a asp-action="Users" class="btn btn-outline-primary w-100 py-3">
                <i class="bi bi-people me-2"></i>Manage Users
            </a>
        </div>
        <div class="col-md-4">
            <a asp-action="Requests" class="btn btn-outline-danger w-100 py-3">
                <i class="bi bi-clipboard2-pulse me-2"></i>Manage Blood Requests
            </a>
        </div>
        <div class="col-md-4">
            <a asp-action="Donations" class="btn btn-outline-success w-100 py-3">
                <i class="bi bi-heart-pulse me-2"></i>Manage Donations
            </a>
        </div>
    </div>

    <!-- Recent Requests Table -->
    <div class="card shadow-sm">
        <div class="card-header bg-danger text-white d-flex justify-content-between align-items-center">
            <h5 class="mb-0"><i class="bi bi-clock-history me-2"></i>Recent Blood Requests</h5>
            <a asp-action="Requests" class="btn btn-sm btn-light">View All</a>
        </div>
        <div class="card-body p-0">
            <div class="table-responsive">
                <table class="table table-hover mb-0 align-middle">
                    <thead class="table-light">
                        <tr>
                            <th>Patient</th>
                            <th>Blood Group</th>
                            <th>Hospital</th>
                            <th>City</th>
                            <th>Urgency</th>
                            <th>Status</th>
                            <th>Posted By</th>
                            <th>Date</th>
                            <th>Actions</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var r in Model)
                        {
                            <tr>
                                <td>@r.PatientName</td>
                                <td><span class="badge bg-danger">@r.BloodGroup</span></td>
                                <td>@r.Hospital</td>
                                <td>@r.City</td>
                                <td>
                                    <span class="@(r.UrgencyLevel == BloodDonationApp.Models.UrgencyLevel.Critical ? "text-danger fw-bold" :
                                                   r.UrgencyLevel == BloodDonationApp.Models.UrgencyLevel.Urgent ? "text-warning fw-bold" : "text-success")">
                                        @r.UrgencyLevel
                                    </span>
                                </td>
                                <td>
                                    <span class="badge @(r.Status == BloodDonationApp.Models.RequestStatus.Open ? "bg-success" :
                                                         r.Status == BloodDonationApp.Models.RequestStatus.Fulfilled ? "bg-primary" : "bg-secondary")">
                                        @r.Status
                                    </span>
                                </td>
                                <td>@(r.User?.FullName ?? "—")</td>
                                <td>@r.CreatedAt.ToString("MMM dd, yyyy")</td>
                                <td>
                                    <form asp-action="DeleteRequest" asp-route-id="@r.Id" method="post"
                                          onsubmit="return confirm('Delete this request?')">
                                        @Html.AntiForgeryToken()
                                        <button class="btn btn-outline-danger btn-sm">
                                            <i class="bi bi-trash"></i>
                                        </button>
                                    </form>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>
